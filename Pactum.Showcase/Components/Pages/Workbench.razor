@page "/workbench"
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Pactum.Showcase.Models
@using Pactum.Showcase.Services
@attribute [Authorize]
@inject DataService DataService
@inject DriveFileService DriveService
@inject CardGenerationService CardService
@rendermode InteractiveServer

<PageTitle>Pactum — Рабочий стол</PageTitle>

<div class="d-flex" style="height: calc(100vh - 56px);">
    <!-- Left: list (30%) -->
    <div class="border-end d-flex flex-column" style="width: 30%; min-width: 250px; max-width: 30%; flex-shrink: 0;">
        <!-- Toolbar -->
        <div class="p-2 border-bottom bg-light" style="flex-shrink: 0;">
            <input type="text" class="form-control form-control-sm mb-1" placeholder="Поиск по названию..."
                   @bind="_searchText" @bind:event="oninput" />
            <div class="d-flex gap-1 mb-1">
                <select class="form-select form-select-sm" @bind="_filterCity">
                    <option value="">Все города</option>
                    @if (_cities != null)
                    {
                        @foreach (var city in _cities)
                        {
                            <option value="@city">@city</option>
                        }
                    }
                </select>
                <select class="form-select form-select-sm" @bind="_filterActivity">
                    <option value="">Все виды</option>
                    @if (_activities != null)
                    {
                        @foreach (var act in _activities)
                        {
                            <option value="@act">@act</option>
                        }
                    }
                </select>
            </div>
            <select class="form-select form-select-sm" @bind="_filterStatus">
                <option value="">Все статусы</option>
                @if (_statuses != null)
                {
                    @foreach (var status in _statuses)
                    {
                        <option value="@status">@status</option>
                    }
                }
            </select>
            <div class="d-flex justify-content-between align-items-center mt-1">
                <small class="text-muted">@FilteredBusinesses.Count из @(_allBusinesses?.Count ?? 0)</small>
                <select class="form-select form-select-sm" style="width: auto;" @bind="_sortBy">
                    <option value="row">По порядку</option>
                    <option value="name">По названию</option>
                    <option value="city">По городу</option>
                </select>
            </div>
        </div>

        <!-- List -->
        <div class="overflow-auto flex-grow-1">
            @if (_allBusinesses == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            }
            else if (FilteredBusinesses.Count == 0)
            {
                <div class="p-3 text-muted">Нет данных</div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var biz in FilteredBusinesses)
                    {
                        var isSelected = _selected?.Id == biz.Id;
                        var fileInfo = _fileInfoCache.GetValueOrDefault(biz.ExternalId ?? "");
                        <button class="list-group-item list-group-item-action @(isSelected ? "active" : "") py-2 px-3"
                                @onclick="() => SelectBusiness(biz)">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="text-truncate me-2">
                                    <div class="fw-semibold text-truncate">@biz.Name</div>
                                    <small class="@(isSelected ? "text-light" : "text-muted")">@biz.City @biz.ActivityType</small>
                                    @if (!string.IsNullOrWhiteSpace(biz.ExternalId))
                                    {
                                        <br/>
                                        <small class="@(isSelected ? "text-light" : "text-muted")">
                                            @biz.ExternalId
                                            @if (fileInfo != null)
                                            {
                                                @if (fileInfo.HasMainDoc)
                                                {
                                                    <span> · @fileInfo.MainDocType</span>
                                                }
                                                else if (fileInfo.HasFolder)
                                                {
                                                    <span> · нет документа</span>
                                                }
                                            }
                                        </small>
                                    }
                                </div>
                            </div>
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Right: detail panel with tabs (70%) -->
    <div class="flex-grow-1 d-flex flex-column">
        @if (_selected == null)
        {
            <div class="d-flex justify-content-center align-items-center flex-grow-1 text-muted">
                <h5>Выберите бизнес из списка</h5>
            </div>
        }
        else
        {
            <!-- Fixed header + tabs -->
            <div class="px-3 pt-3" style="flex-shrink: 0;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">@_selected.Name</h5>
                    @if (!string.IsNullOrWhiteSpace(_selected.ExternalId))
                    {
                        <span class="badge bg-secondary">@_selected.ExternalId</span>
                    }
                </div>

                <ul class="nav nav-tabs">
                    <li class="nav-item">
                        <button class="nav-link @(_activeTab == 0 ? "active" : "")" @onclick="() => SwitchTab(0)">Данные</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_activeTab == 1 ? "active" : "")" @onclick="() => SwitchTab(1)"
                                disabled="@(string.IsNullOrWhiteSpace(_selected.ExternalId))">Схема</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_activeTab == 2 ? "active" : "")" @onclick="() => SwitchTab(2)"
                                disabled="@(string.IsNullOrWhiteSpace(_selected.ExternalId))">Карточка</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_activeTab == 3 ? "active" : "")" @onclick="() => SwitchTab(3)"
                                disabled="@(string.IsNullOrWhiteSpace(_selected.ExternalId))">Картинки</button>
                    </li>
                </ul>
            </div>

            <!-- Scrollable tab content -->
            <div class="overflow-auto flex-grow-1 p-3">
                @if (_activeTab == 0)
                {
                    @RenderDataTab()
                }
                else if (_activeTab == 1)
                {
                    @RenderDocTab(_mainDocHtml, _mainDocError, _mainDocLoading, "схемы")
                }
                else if (_activeTab == 2)
                {
                    @RenderCardTab()
                }
                else if (_activeTab == 3)
                {
                    @RenderImagesTab()
                }
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool _isAdmin;
    private List<BusinessEntity>? _allBusinesses;
    private BusinessEntity? _selected;
    private int _activeTab;
    private bool _initialized;

    // Filters
    private string _searchText = "";
    private string _filterCity = "";
    private string _filterActivity = "";
    private string _filterStatus = "";
    private string _sortBy = "row";
    private List<string>? _cities;
    private List<string>? _activities;
    private List<string>? _statuses;

    // File info cache
    private readonly Dictionary<string, FilePresenceInfo> _fileInfoCache = new();

    // Tab 1: main doc (schema)
    private string? _mainDocHtml;
    private string? _mainDocError;
    private bool _mainDocLoading;
    private string? _mainDocLoadedForId;

    // Tab 2: card doc
    private string? _cardDocHtml;
    private string? _cardDocError;
    private bool _cardDocLoading;
    private bool _cardGenerating;
    private string? _cardDocLoadedForId;

    // Tab 3: images
    private List<ImageInfo>? _images;
    private string? _imagesError;
    private bool _imagesLoading;
    private string? _imagesLoadedForId;

    private List<BusinessEntity> FilteredBusinesses
    {
        get
        {
            if (_allBusinesses == null) return [];

            var result = _allBusinesses.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_searchText))
                result = result.Where(b =>
                    b.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                    || (b.ExternalId ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(_filterCity))
                result = result.Where(b => b.City == _filterCity);

            if (!string.IsNullOrWhiteSpace(_filterActivity))
                result = result.Where(b => b.ActivityType == _filterActivity);

            if (!string.IsNullOrWhiteSpace(_filterStatus))
                result = result.Where(b => b.Status == _filterStatus);

            result = _sortBy switch
            {
                "name" => result.OrderBy(b => b.Name),
                "city" => result.OrderBy(b => b.City).ThenBy(b => b.Name),
                _ => result.OrderBy(b => b.SheetRow)
            };

            return result.ToList();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            if (AuthState != null)
            {
                var state = await AuthState;
                _isAdmin = state.User.IsInRole("Admin");
            }
            _allBusinesses = await DataService.GetAllAsync();

            _cities = _allBusinesses
                .Select(b => b.City)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Distinct()
                .OrderBy(c => c)
                .ToList();

            _activities = _allBusinesses
                .Select(b => b.ActivityType)
                .Where(a => !string.IsNullOrWhiteSpace(a))
                .Distinct()
                .OrderBy(a => a)
                .ToList();

            _statuses = _allBusinesses
                .Select(b => b.Status)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct()
                .OrderBy(s => s)
                .ToList();

            _ = LoadFileInfoAsync();
            StateHasChanged();
        }
    }

    private async Task LoadFileInfoAsync()
    {
        if (_allBusinesses == null) return;

        foreach (var biz in _allBusinesses.Where(b => !string.IsNullOrWhiteSpace(b.ExternalId)))
        {
            if (_fileInfoCache.ContainsKey(biz.ExternalId!))
                continue;
            try
            {
                var info = await DriveService.CheckFilesAsync(biz.ExternalId!);
                _fileInfoCache[biz.ExternalId!] = info;
                await InvokeAsync(StateHasChanged);
            }
            catch { }
        }
    }

    private async Task SelectBusiness(BusinessEntity biz)
    {
        _selected = biz;
        _mainDocLoadedForId = null;
        _cardDocLoadedForId = null;
        _imagesLoadedForId = null;

        if (_activeTab > 0)
            await SwitchTab(_activeTab);
    }

    private async Task SwitchTab(int tab)
    {
        _activeTab = tab;
        if (_selected == null || string.IsNullOrWhiteSpace(_selected.ExternalId))
            return;

        var eid = _selected.ExternalId;

        if (tab == 1 && _mainDocLoadedForId != eid)
        {
            _mainDocLoading = true;
            _mainDocHtml = null;
            _mainDocError = null;
            StateHasChanged();
            var (html, error) = await DriveService.ReadMainDocAsync(eid);
            _mainDocHtml = html;
            _mainDocError = error;
            _mainDocLoading = false;
            _mainDocLoadedForId = eid;
        }
        else if (tab == 2 && _cardDocLoadedForId != eid)
        {
            _cardDocLoading = true;
            _cardDocHtml = null;
            _cardDocError = null;
            StateHasChanged();
            var (html, error) = await DriveService.ReadCardDocAsync(eid);
            _cardDocHtml = html;
            _cardDocError = error;
            _cardDocLoading = false;
            _cardDocLoadedForId = eid;
        }
        else if (tab == 3 && _imagesLoadedForId != eid)
        {
            _imagesLoading = true;
            _images = null;
            _imagesError = null;
            StateHasChanged();
            var (images, error) = await DriveService.ListImagesAsync(eid);
            _images = images;
            _imagesError = error;
            _imagesLoading = false;
            _imagesLoadedForId = eid;
        }
    }

    private async Task GenerateCard()
    {
        if (_selected == null || string.IsNullOrWhiteSpace(_selected.ExternalId))
            return;

        _cardGenerating = true;
        _cardDocError = null;
        _cardDocHtml = null;
        StateHasChanged();

        var (success, message) = await CardService.GenerateCardAsync(_selected.ExternalId);

        if (success)
        {
            // Reload card content
            _cardDocLoadedForId = null;
            var (html, error) = await DriveService.ReadCardDocAsync(_selected.ExternalId);
            _cardDocHtml = html;
            _cardDocError = error;
            _cardDocLoadedForId = _selected.ExternalId;
        }
        else
        {
            _cardDocError = message;
        }

        _cardGenerating = false;
    }

    private RenderFragment RenderDataTab() => __builder =>
    {
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-sm table-striped mb-0">
                    @foreach (var prop in GetProperties(_selected!))
                    {
                        <tr>
                            <th class="text-muted ps-3" style="width: 35%">@prop.Key</th>
                            <td style="white-space: pre-wrap">@prop.Value</td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    };

    private RenderFragment RenderDocTab(string? html, string? error, bool loading, string docType) => __builder =>
    {
        if (loading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2 text-muted">Загрузка @docType...</p>
            </div>
        }
        else if (error != null)
        {
            <div class="alert alert-warning">@((MarkupString)error)</div>
        }
        else if (html != null)
        {
            <div class="card">
                <div class="card-body doc-content">
                    @((MarkupString)html)
                </div>
            </div>
        }
    };

    private RenderFragment RenderCardTab() => __builder =>
    {
        @if (_isAdmin)
        {
            <div class="mb-3">
                <button class="btn btn-primary btn-sm" @onclick="GenerateCard"
                        disabled="@(_cardGenerating || _cardDocLoading)">
                    @if (_cardGenerating)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>Генерация...</span>
                    }
                    else
                    {
                        <span>Сгенерировать карточку</span>
                    }
                </button>
            </div>
        }

        @if (_cardDocLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2 text-muted">Загрузка карточки...</p>
            </div>
        }
        else if (_cardDocError != null)
        {
            <div class="alert alert-warning">@((MarkupString)_cardDocError)</div>
        }
        else if (_cardDocHtml != null)
        {
            <div class="card">
                <div class="card-body doc-content">
                    @((MarkupString)_cardDocHtml)
                </div>
            </div>
        }
    };

    private RenderFragment RenderImagesTab() => __builder =>
    {
        if (_imagesLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2 text-muted">Загрузка картинок...</p>
            </div>
        }
        else if (_imagesError != null)
        {
            <div class="alert alert-warning">@_imagesError</div>
        }
        else if (_images != null && _images.Count == 0)
        {
            <div class="text-muted text-center py-4">Картинок нет</div>
        }
        else if (_images != null)
        {
            <div class="row g-3">
                @foreach (var img in _images)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="card h-100">
                            <img src="/api/images/@img.Id" class="card-img-top" alt="@img.Name"
                                 style="object-fit: cover; height: 200px;" loading="lazy" />
                            <div class="card-body p-2">
                                <small class="text-muted text-truncate d-block">@img.Name</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    };

    private Dictionary<string, string> GetProperties(BusinessEntity biz)
    {
        try
        {
            return JsonSerializer.Deserialize<Dictionary<string, string>>(biz.PropertiesJson) ?? new();
        }
        catch
        {
            return new();
        }
    }
}
