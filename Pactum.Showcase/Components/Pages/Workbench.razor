@page "/workbench"
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Pactum.Showcase.Models
@using Pactum.Showcase.Services
@attribute [Authorize]
@inject DataService DataService
@rendermode InteractiveServer

<PageTitle>Pactum — Рабочий стол</PageTitle>

<div class="d-flex" style="height: calc(100vh - 56px);">
    <!-- Left: list (30%) -->
    <div class="border-end overflow-auto" style="width: 30%; min-width: 250px; max-width: 30%; flex-shrink: 0;">
        @if (_businesses == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary"></div>
            </div>
        }
        else if (_businesses.Count == 0)
        {
            <div class="p-3 text-muted">Нет данных. Загрузите из Админ-панели.</div>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var biz in _businesses)
                {
                    var isSelected = _selected?.Id == biz.Id;
                    <button class="list-group-item list-group-item-action @(isSelected ? "active" : "") py-2 px-3"
                            @onclick="() => SelectBusiness(biz)">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="text-truncate me-2">
                                <div class="fw-semibold text-truncate">@biz.Name</div>
                                <small class="@(isSelected ? "text-light" : "text-muted")">@biz.City @biz.ActivityType</small>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(biz.ExternalId))
                            {
                                <span class="badge @(isSelected ? "bg-light text-dark" : "bg-secondary") text-nowrap">@biz.ExternalId</span>
                            }
                        </div>
                    </button>
                }
            </div>
        }
    </div>

    <!-- Right: detail panel with tabs (70%) -->
    <div class="flex-grow-1 overflow-auto">
        @if (_selected == null)
        {
            <div class="d-flex justify-content-center align-items-center h-100 text-muted">
                <div class="text-center">
                    <h5>Выберите бизнес из списка</h5>
                </div>
            </div>
        }
        else
        {
            <div class="p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">@_selected.Name</h5>
                    <span class="badge bg-secondary">@_selected.ExternalId</span>
                </div>

                <!-- Tabs -->
                <ul class="nav nav-tabs">
                    <li class="nav-item">
                        <button class="nav-link @(_activeTab == 0 ? "active" : "")" @onclick="() => _activeTab = 0">Данные</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_activeTab == 1 ? "active" : "")" @onclick="() => _activeTab = 1">Схема</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_activeTab == 2 ? "active" : "")" @onclick="() => _activeTab = 2">Описание</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_activeTab == 3 ? "active" : "")" @onclick="() => _activeTab = 3">Картинки</button>
                    </li>
                </ul>

                <div class="tab-content pt-3">
                    @if (_activeTab == 0)
                    {
                        <!-- Данные -->
                        <div class="card">
                            <div class="card-body p-0">
                                <table class="table table-sm table-striped mb-0">
                                    @foreach (var prop in GetProperties(_selected))
                                    {
                                        <tr>
                                            <th class="text-muted ps-3" style="width: 35%">@prop.Key</th>
                                            <td>@prop.Value</td>
                                        </tr>
                                    }
                                </table>
                            </div>
                        </div>
                    }
                    else if (_activeTab == 1)
                    {
                        <div class="text-muted p-4 text-center">Схема — будет реализовано</div>
                    }
                    else if (_activeTab == 2)
                    {
                        <div class="text-muted p-4 text-center">Описание — будет реализовано</div>
                    }
                    else if (_activeTab == 3)
                    {
                        <div class="text-muted p-4 text-center">Картинки — будет реализовано</div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<BusinessEntity>? _businesses;
    private BusinessEntity? _selected;
    private int _activeTab;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            _businesses = await DataService.GetAllAsync();
            StateHasChanged();
        }
    }

    private void SelectBusiness(BusinessEntity biz)
    {
        _selected = biz;
        _activeTab = 0;
    }

    private Dictionary<string, string> GetProperties(BusinessEntity biz)
    {
        try
        {
            return JsonSerializer.Deserialize<Dictionary<string, string>>(biz.PropertiesJson) ?? new();
        }
        catch
        {
            return new();
        }
    }
}
