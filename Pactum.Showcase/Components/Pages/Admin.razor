@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Pactum.Showcase.Services
@attribute [Authorize(Roles = "Admin")]
@inject DataService DataService
@rendermode InteractiveServer

<PageTitle>Pactum — Администрирование</PageTitle>

<div class="container py-3">
    <h4 class="mb-4">Администрирование</h4>

    @if (_message != null)
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible">
            @_message
            <button type="button" class="btn-close" @onclick="() => _message = null"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header">
            <strong>База данных</strong>
            <span class="text-muted ms-2">(@_count записей)</span>
        </div>
        <div class="card-body">
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-primary" @onclick="ReloadData" disabled="@_busy">
                    @if (_busy && _currentOp == "reload")
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Загрузить из Google Sheets
                </button>

                <button class="btn btn-danger" @onclick="ShowClearConfirm" disabled="@_busy">
                    Очистить базу
                </button>
            </div>

            @if (_showClearConfirm)
            {
                <div class="alert alert-warning mt-3">
                    <strong>Внимание!</strong> Это удалит все данные из локальной базы.
                    <div class="mt-2">
                        <button class="btn btn-danger btn-sm me-2" @onclick="ClearDatabase" disabled="@_busy">
                            @if (_busy && _currentOp == "clear")
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Да, очистить
                        </button>
                        <button class="btn btn-secondary btn-sm" @onclick="() => _showClearConfirm = false">Отмена</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string? _message;
    private bool _isError;
    private bool _busy;
    private string? _currentOp;
    private bool _showClearConfirm;
    private int _count;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            _count = await DataService.GetCountAsync();
            StateHasChanged();
        }
    }

    private async Task ReloadData()
    {
        _busy = true;
        _currentOp = "reload";
        _message = null;
        try
        {
            _count = await DataService.ReloadFromSheetsAsync();
            _message = $"Загружено {_count} записей из Google Sheets в базу";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = $"Ошибка: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _busy = false;
            _currentOp = null;
        }
    }

    private async Task ClearDatabase()
    {
        _busy = true;
        _currentOp = "clear";
        _message = null;
        _showClearConfirm = false;
        try
        {
            await DataService.ClearAsync();
            _count = 0;
            _message = "База очищена";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = $"Ошибка: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _busy = false;
            _currentOp = null;
        }
    }

    private void ShowClearConfirm()
    {
        _showClearConfirm = true;
    }
}
