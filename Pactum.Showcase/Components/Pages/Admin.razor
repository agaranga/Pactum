@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Pactum.Showcase.Services
@attribute [Authorize(Roles = "Admin")]
@inject DataService DataService
@inject DriveFileService DriveService
@inject CardGenerationService CardService
@inject GoogleOAuthService GoogleOAuth
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Pactum — Администрирование</PageTitle>

<div class="container py-3">
    <h4 class="mb-4">Администрирование</h4>

    @if (_message != null)
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible">
            @_message
            <button type="button" class="btn-close" @onclick="() => _message = null"></button>
        </div>
    }

    <!-- Database -->
    <div class="card mb-4">
        <div class="card-header">
            <strong>База данных</strong>
            <span class="text-muted ms-2">(@_count записей)</span>
        </div>
        <div class="card-body">
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-primary" @onclick="ReloadData" disabled="@_busy">
                    @if (_busy && _currentOp == "reload")
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Загрузить из Google Sheets
                </button>

                <button class="btn btn-danger" @onclick="ShowClearConfirm" disabled="@_busy">
                    Очистить базу
                </button>
            </div>

            @if (_showClearConfirm)
            {
                <div class="alert alert-warning mt-3">
                    <strong>Внимание!</strong> Это удалит все данные из локальной базы.
                    <div class="mt-2">
                        <button class="btn btn-danger btn-sm me-2" @onclick="ClearDatabase" disabled="@_busy">
                            @if (_busy && _currentOp == "clear")
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Да, очистить
                        </button>
                        <button class="btn btn-secondary btn-sm" @onclick="() => _showClearConfirm = false">Отмена</button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Google Drive connection -->
    <div class="card mb-4">
        <div class="card-header">
            <strong>Google Drive</strong>
        </div>
        <div class="card-body">
            @if (GoogleOAuth.IsAuthorized)
            {
                <span class="text-success">Подключен</span>
            }
            else
            {
                <p class="text-muted">Для создания файлов на Google Drive необходимо подключить аккаунт.</p>
                <a href="/api/auth/google" class="btn btn-outline-primary">Подключить Google Drive</a>
            }
            @if (_googleStatus == "ok")
            {
                <div class="alert alert-success mt-2 mb-0">Google Drive успешно подключен!</div>
            }
            else if (_googleStatus == "error")
            {
                <div class="alert alert-danger mt-2 mb-0">Ошибка подключения Google Drive</div>
            }
        </div>
    </div>

    <!-- Card generation -->
    <div class="card mb-4">
        <div class="card-header">
            <strong>Генерация карточек</strong>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="cardGenMode" id="modeMissing"
                           checked="@(_cardGenMode == "missing")" @onchange="SetModeMissing" />
                    <label class="form-check-label" for="modeMissing">
                        Недостающие — генерировать только где нет карточки
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="cardGenMode" id="modeAll"
                           checked="@(_cardGenMode == "all")" @onchange="SetModeAll" />
                    <label class="form-check-label" for="modeAll">
                        Все — перегенерировать все карточки заново
                    </label>
                </div>
            </div>

            <button class="btn btn-primary" @onclick="GenerateCards" disabled="@_busy">
                @if (_busy && _currentOp == "cards")
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    <span>Генерация @_cardGenProgress...</span>
                }
                else
                {
                    <span>Сгенерировать карточки</span>
                }
            </button>
        </div>
    </div>
</div>

@code {
    private string? _message;
    private bool _isError;
    private bool _busy;
    private string? _currentOp;
    private bool _showClearConfirm;
    private int _count;
    private bool _initialized;
    private string _cardGenMode = "missing";
    private string _cardGenProgress = "";
    private string? _googleStatus;

    [SupplyParameterFromQuery(Name = "google")]
    public string? GoogleStatus { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            _googleStatus = GoogleStatus;
            _count = await DataService.GetCountAsync();
            StateHasChanged();
        }
    }

    private async Task ReloadData()
    {
        _busy = true;
        _currentOp = "reload";
        _message = null;
        try
        {
            _count = await DataService.ReloadFromSheetsAsync();
            _message = $"Загружено {_count} записей из Google Sheets в базу";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = $"Ошибка: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _busy = false;
            _currentOp = null;
        }
    }

    private async Task ClearDatabase()
    {
        _busy = true;
        _currentOp = "clear";
        _message = null;
        _showClearConfirm = false;
        try
        {
            await DataService.ClearAsync();
            _count = 0;
            _message = "База очищена";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = $"Ошибка: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _busy = false;
            _currentOp = null;
        }
    }

    private async Task GenerateCards()
    {
        _busy = true;
        _currentOp = "cards";
        _message = null;
        _cardGenProgress = "";
        try
        {
            var all = await DataService.GetAllAsync();
            var withId = all.Where(b => !string.IsNullOrWhiteSpace(b.ExternalId)).ToList();

            int generated = 0, skipped = 0, failed = 0;

            for (int i = 0; i < withId.Count; i++)
            {
                var biz = withId[i];
                _cardGenProgress = $"({i + 1}/{withId.Count}) {biz.Name}";
                StateHasChanged();

                // Check if card already exists (skip if mode = missing)
                if (_cardGenMode == "missing")
                {
                    var info = await DriveService.CheckFilesAsync(biz.ExternalId!);
                    if (info.HasCardDoc)
                    {
                        skipped++;
                        continue;
                    }
                }

                var (success, msg) = await CardService.GenerateCardAsync(biz.ExternalId!);
                if (success)
                    generated++;
                else
                    failed++;
            }

            _message = $"Готово. Сгенерировано: {generated}, пропущено: {skipped}, ошибок: {failed}";
            _isError = failed > 0;
        }
        catch (Exception ex)
        {
            _message = $"Ошибка: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _busy = false;
            _currentOp = null;
            _cardGenProgress = "";
        }
    }

    private void ShowClearConfirm() => _showClearConfirm = true;
    private void SetModeMissing() => _cardGenMode = "missing";
    private void SetModeAll() => _cardGenMode = "all";
}
