@page "/"
@page "/showcase"
@using Microsoft.AspNetCore.Authorization
@using Pactum.Showcase.Models
@using Pactum.Showcase.Services
@attribute [Authorize]
@inject GoogleSheetsService SheetsService
@inject DescriptionService DescriptionService
@rendermode InteractiveServer

<PageTitle>Pactum Showcase</PageTitle>

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Pactum Showcase</h1>
        <button class="btn btn-outline-primary" @onclick="LoadBusinesses" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            Обновить из таблицы
        </button>
    </div>

    @if (_error != null)
    {
        <div class="alert alert-danger alert-dismissible">
            @_error
            <button type="button" class="btn-close" @onclick="() => _error = null"></button>
        </div>
    }

    @if (_businesses == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Загрузка данных из Google Sheets...</p>
        </div>
    }
    else if (_businesses.Count == 0)
    {
        <div class="alert alert-info">Таблица пуста или не содержит данных.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var biz in _businesses)
            {
                <div class="col-12 col-lg-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">@biz.Name</h5>
                            <span class="badge bg-secondary">Строка @biz.Row</span>
                        </div>
                        <div class="card-body">
                            @if (biz.GeneratedDescription != null)
                            {
                                <div class="generated-description">
                                    @((MarkupString)Markdig.Markdown.ToHtml(biz.GeneratedDescription))
                                </div>
                            }
                            else
                            {
                                <table class="table table-sm table-borderless mb-0">
                                    @foreach (var prop in biz.Properties)
                                    {
                                        <tr>
                                            <th class="text-muted" style="width:40%">@prop.Key</th>
                                            <td>@prop.Value</td>
                                        </tr>
                                    }
                                </table>
                            }
                        </div>
                        <div class="card-footer bg-transparent">
                            @if (biz.GeneratedDescription != null)
                            {
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-secondary" @onclick="() => biz.GeneratedDescription = null">
                                        Показать параметры
                                    </button>
                                    <button class="btn btn-outline-primary" @onclick="() => GenerateDescription(biz)" disabled="@biz.IsGenerating">
                                        Перегенерировать
                                    </button>
                                    <button class="btn btn-outline-success" @onclick="() => CopyToClipboard(biz.GeneratedDescription)">
                                        Копировать
                                    </button>
                                </div>
                            }
                            else if (_isAdmin)
                            {
                                <button class="btn btn-sm btn-primary" @onclick="() => GenerateDescription(biz)" disabled="@biz.IsGenerating">
                                    @if (biz.IsGenerating)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                        <span>Генерация...</span>
                                    }
                                    else
                                    {
                                        <span>Сгенерировать описание</span>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (_isAdmin)
        {
            <div class="mt-4">
                <button class="btn btn-success" @onclick="GenerateAll" disabled="@_generatingAll">
                    @if (_generatingAll)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>Генерация всех (@_generatedCount / @_businesses.Count)...</span>
                    }
                    else
                    {
                        <span>Сгенерировать все описания</span>
                    }
                </button>
            </div>
        }
    }
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool _isAdmin;
    private List<Business>? _businesses;
    private string? _error;
    private bool _loading;
    private bool _generatingAll;
    private int _generatedCount;

    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            if (AuthState != null)
            {
                var state = await AuthState;
                _isAdmin = state.User.IsInRole("Admin");
            }
            await LoadBusinesses();
            StateHasChanged();
        }
    }

    private async Task LoadBusinesses()
    {
        _loading = true;
        _error = null;
        try
        {
            _businesses = await SheetsService.GetBusinessesAsync();
        }
        catch (Exception ex)
        {
            _error = $"Ошибка загрузки: {ex.Message}";
            _businesses = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task GenerateDescription(Business biz)
    {
        biz.IsGenerating = true;
        try
        {
            biz.GeneratedDescription = await DescriptionService.GenerateDescriptionAsync(biz);
        }
        catch (Exception ex)
        {
            _error = $"Ошибка генерации для {biz.Name}: {ex.Message}";
        }
        finally
        {
            biz.IsGenerating = false;
        }
    }

    private async Task GenerateAll()
    {
        _generatingAll = true;
        _generatedCount = 0;
        foreach (var biz in _businesses!)
        {
            if (biz.GeneratedDescription == null)
            {
                await GenerateDescription(biz);
                _generatedCount++;
                StateHasChanged();
            }
            else
            {
                _generatedCount++;
            }
        }
        _generatingAll = false;
    }

    private async Task CopyToClipboard(string text)
    {
        // Will be handled via JS interop
    }
}
