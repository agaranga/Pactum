@page "/"
@page "/showcase"
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Pactum.Showcase.Models
@using Pactum.Showcase.Services
@attribute [Authorize]
@inject DataService DataService
@rendermode InteractiveServer

<PageTitle>Pactum Showcase</PageTitle>

<div class="container-fluid px-4 py-3">
    <h4 class="mb-3">Витрина</h4>

    @if (_businesses == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Загрузка...</p>
        </div>
    }
    else if (_businesses.Count == 0)
    {
        <div class="alert alert-info">Нет данных. Загрузите из Админ-панели.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var biz in _businesses)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title">@biz.Name</h6>
                            @if (!string.IsNullOrWhiteSpace(biz.ActivityType))
                            {
                                <p class="card-text text-muted small mb-1">@biz.ActivityType</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(biz.City) || !string.IsNullOrWhiteSpace(biz.Address))
                            {
                                <p class="card-text small">@biz.City @biz.Address</p>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(biz.ExternalId))
                        {
                            <div class="card-footer bg-transparent">
                                <span class="badge bg-secondary">@biz.ExternalId</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<BusinessEntity>? _businesses;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            _businesses = await DataService.GetAllAsync();
            StateHasChanged();
        }
    }
}
